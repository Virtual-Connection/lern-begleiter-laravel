APP_NAME="Lern-Begleiter"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_PORT=8080

APP_LOCALE=de
APP_FALLBACK_LOCALE=de
APP_FAKER_LOCALE=de_DE

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=data/app/database.sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Neuron AI – Ollama (Chat + Embeddings) / Chroma
NEURON_AI_PROVIDER=ollama
NEURON_EMBEDDING_PROVIDER=ollama
NEURON_STORE_PROVIDER=chroma

# Im Compose-Netz: Service-Namen. Lokal ohne Docker: http://localhost:11434/api
OLLAMA_URL=http://ollama:11434/api
OLLAMA_MODEL=qwen2.5:1.5b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Im Compose-Netz: chroma. Lokal ohne Docker nur sinnvoll mit Port-Mapping.
CHROMA_HOST=http://chroma:8000
CHROMA_COLLECTION=companion
CHROMA_TENANT=default_tenant
CHROMA_DATABASE=default_database

COMPANION_TOP_K=5
COMPANION_SCORE_THRESHOLD=0.2
COMPANION_TIMEOUT_EMBEDDING=120
COMPANION_TIMEOUT_INDEX=120
COMPANION_TIMEOUT_SEARCH=15
COMPANION_TIMEOUT_LLM=180
